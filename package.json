{
  "name": "poker-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Poker 1v1 frontend for playing against local/remote bot API",
  "main": "server.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.cjs",
    "gto:login": "node ./scripts/gto_login.cjs",
    "gto:login:env": "powershell -ExecutionPolicy Bypass -File ./scripts/start_gto_login.ps1",
    "gto:probe": "node ./scripts/gto_site_probe.cjs",
    "gto:probe:env": "powershell -ExecutionPolicy Bypass -File ./scripts/start_gto_probe.ps1",
    "gto:hands:export": "node ./scripts/export_hands_report_full.cjs",
    "gto:hands:export:env": "powershell -ExecutionPolicy Bypass -File ./scripts/start_gto_hands_export.ps1",
    "gto:autopilot:env": "powershell -ExecutionPolicy Bypass -File ./scripts/run_gto_autopilot.ps1",
    "gto:gameapi": "node ./scripts/gto_gameapi_bridge.cjs",
    "gto:gameapi:env": "powershell -ExecutionPolicy Bypass -File ./scripts/start_gto_gameapi_bridge.ps1",
    "gto:dataset:build": "node ./scripts/build_gto_live_dataset.cjs",
    "gto:dataset:fit": "node ./scripts/fit_live_tune_weights.cjs",
    "gto:dataset:validate": "node ./scripts/validate_live_tune_weights.cjs",
    "bridge:gto": "node ./scripts/gto_live_bridge.cjs",
    "bridge:gto:env": "powershell -ExecutionPolicy Bypass -File ./scripts/start_gto_bridge.ps1",
    "start:fullgame:cpp": "powershell -ExecutionPolicy Bypass -File ./scripts/start_server_cpp.ps1",
    "train:cpp:model": "powershell -ExecutionPolicy Bypass -File ./scripts/run_cpp_model_pipeline.ps1",
    "train:blueprint:v1:js-experimental": "node ./scripts/train_blueprint_v1_postflop.cjs",
    "battery": "node ./scripts/opponent_battery.cjs",
    "postinstall": "npm run build"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@letele/playing-cards": "^0.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "express": "^4.21.2",
    "playwright": "^1.58.2",
    "poker-evaluator": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "vite": "^5.2.0"
  }
}